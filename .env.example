# ═══════════════════════════════════════════════════════════════
# CreatorHub — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Supabase PostgreSQL) ───────────────────────────
# Connection pooler URL (for Prisma Client queries)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection URL (for Prisma Migrate)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Payment Gateway (Mayar) ──────────────────────────────
# API key for creating invoices (Bearer token)
PAYMENT_GATEWAY_SECRET=your_mayar_api_key
# Secret key for verifying payment webhook signatures (x-callback-token)
PAYMENT_GATEWAY_WEBHOOK_SECRET=your_webhook_secret
